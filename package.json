{
  "name": "vscode-simple-start",
  "displayName": "Simple Start",
  "description": "Custom startup page for choosing a project from a configured root folder.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-simple-start.openStartPage",
        "title": "Simple Start: Open Start Page"
      },
      {
        "command": "vscode-simple-start.selectProjectsRoot",
        "title": "Simple Start: Select Projects Root"
      },
      {
        "command": "vscode-simple-start.refreshStartPage",
        "title": "Simple Start: Refresh Start Page"
      }
    ],
    "configuration": {
      "title": "Simple Start",
      "properties": {
        "simpleStart.replaceDefaultStartupPage": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Set VS Code's built-in startup editor to 'none' so Simple Start can be the primary startup page in empty windows."
        },
        "simpleStart.openOnStartup": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Open the Simple Start page when VS Code launches with no folder or workspace open."
        },
        "simpleStart.projectsRoot": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "Absolute path to the folder that contains your project folders."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
