{
  "name": "simple-start",
  "displayName": "Simple Start",
  "publisher": "ElectricPants",
  "description": "Custom startup page for choosing a project from a configured root folder. Simple and opinionated, with a focus on keyboard navigation and quickness",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjw7444/vscode-simple-start"
  },
  "homepage": "https://github.com/sjw7444/vscode-simple-start#readme",
  "bugs": {
    "url": "https://github.com/sjw7444/vscode-simple-start/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "startup",
    "start-page",
    "projects",
    "workspace",
    "dashboard"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "simple-start.openStartPage",
        "title": "simple-start: Open Start Page"
      },
      {
        "command": "simple-start.selectProjectsRoot",
        "title": "simple-start: Select Projects Root"
      },
      {
        "command": "simple-start.refreshStartPage",
        "title": "simple-start: Refresh Start Page"
      }
    ],
    "configuration": {
      "title": "simple-start",
      "properties": {
        "simpleStart.openOnStartup": {
          "type": "boolean",
          "default": true,
          "scope": "application",
          "description": "Open the simple-start page when VS Code launches with no folder or workspace open and workbench.startupEditor is set to 'none'."
        },
        "simpleStart.projectsRoot": {
          "type": "string",
          "default": "",
          "scope": "application",
          "description": "Absolute path to the folder that contains your project folders."
        },
        "simpleStart.applicationIconMap": {
          "type": "object",
          "scope": "application",
          "default": {},
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "description": "Map application names to icon candidate paths (relative to each project root). Matching apps are used to prioritize icon lookup."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package:vsix": "vsce package",
    "publish:vsce": "vsce publish",
    "publish:ovsx": "ovsx publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "ovsx": "^0.10.5"
  }
}
